{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "version": "2.1.1",
  "description": "__MSG_extensionDescription__",
  "permissions": [
    "storage",
    "tabs",
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
	"contextMenus"
  ],
  "incognito": "spanning",
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
"background": {
    "scripts": ["scripts/global/background.js"]
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "scripts/global/contentScanner.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "pages/PopupMenu.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "32": "assets/icons/icon32.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "pages/UrgeTest_initial.html",
        "DB/adult-keywords.json"
      ],
      "matches": [
        "http://*/*",
        "https://*/*"
      ]
    }
  ],
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "default_locale": "en",
  "browser_specific_settings": {
    "gecko": {
      "id": "{a50b0ef8-7ffe-4628-b2f7-57ea96a6ae84}",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    },
	"gecko_android": {
    "strict_min_version": "142.0"
  }
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "default_rules",
        "enabled": true,
        "path": "DB/default_rules.json"
      }
    ]
  }
}
